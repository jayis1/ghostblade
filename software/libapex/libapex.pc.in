# libapex.pc.in — pkg-config template for libapex
#
# Copyright (C) 2026 GhostBlade Project
# SPDX-License-Identifier: GPL-2.0-or-later
#
# This template is processed by the build system to generate libapex.pc
# with the correct prefix, libdir, and includedir values.
#
# Install:
#   make install   → installs libapex.pc to $(DESTDIR)$(PREFIX)/lib/pkgconfig/
#
# Usage:
#   pkg-config --cflags --libs libapex

prefix=@PREFIX@
exec_prefix=@PREFIX@
libdir=@PREFIX@/lib
includedir=@PREFIX@/include

Name: libapex
Description: GhostBlade SPI Bridge userspace library (RK3576 <-> RP2350B)
Version: 0.1.0
URL: https://github.com/jayis1/ghostblade
Libs: -L${libdir} -lapex
Libs.private: -lm -lpthread
Cflags: -I${includedir}