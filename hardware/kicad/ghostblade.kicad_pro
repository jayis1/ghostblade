(kicad_pro (version 20240505)

  (general
    (project "GhostBlade")
    (project_rev "1.0")
    (comment 0 "Project Cyber-Swiss — Advanced Mobile Pentesting Lab")
    (comment 1 "Dual-Processor: RK3576 + RP2350B")
    (comment 2 "6-Layer FR-4, 1.6mm, IPC Class 3")
    (comment 3 "CERN-OHL-S v2")
  )

  (board
    (design_settings
      (layer_stack
        (layer "F.Cu" "Top Signal" "copper" 1)
        (layer "In1.Cu" "Ground Plane" "copper" 2)
        (layer "In2.Cu" "Inner Signal" "copper" 3)
        (layer "In3.Cu" "Power Plane" "copper" 4)
        (layer "In4.Cu" "Ground Plane 2" "copper" 5)
        (layer "B.Cu" "Bottom Signal" "copper" 6)
      )
      (copper_layers 6)
      (copper_finish "ENIG")
      (board_thickness 1.6)
    )
  )

  (schematic
    (symbol_libraries
      (logical_lib "ghostblade-symbols")
    )
  )

  (pcb
    (footprint_libraries
      (logical_lib "ghostblade-footprints")
    )
  )

  (net_classes
    (net_class "Default" "")
    (net_class "Power"
      (clearance 0.2)
      (trace_width 0.4)
      (via_dia 0.8)
      (via_drill 0.4)
    )
    (net_class "High-Speed"
      (clearance 0.15)
      (trace_width 0.15)
      (via_dia 0.4)
      (via_drill 0.2)
      (diff_pair_gap 0.127)
      (diff_pair_width 0.102)
    )
    (net_class "RF"
      (clearance 0.3)
      (trace_width 0.142)
      (via_dia 0.3)
      (via_drill 0.15)
    )
    (net_class "DDR"
      (clearance 0.1)
      (trace_width 0.1)
      (via_dia 0.3)
      (via_drill 0.15)
      (diff_pair_gap 0.127)
      (diff_pair_width 0.102)
    )
  )
)