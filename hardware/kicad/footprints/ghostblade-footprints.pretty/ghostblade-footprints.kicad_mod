(kicad_footprint_lib (version 20240505) (generator "apex-one-cad")

  ;; ================================================================
  ;; FCBGA-732 — Rockchip RK3576 (0.65mm pitch, 23x23mm body)
  ;; ================================================================
  (footprint "FCBGA-732_0.65mm" (version 20240505) (generator "apex-one-cad")
    (layer "F.Cu")
    (descr "Rockchip RK3576 FCBGA-732, 0.65mm pitch, 23x23mm body")
    (tags "BGA RK3576 FCBGA-732")
    (attr smd)
    (fp_text reference "U**" (at 0 -12.5) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (fp_text value "FCBGA-732_0.65mm" (at 0 12.5) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    
    ;; Outline
    (fp_line (start -11.5 -11.5) (end 11.5 -11.5) (layer "F.SilkS") (width 0.12))
    (fp_line (start 11.5 -11.5) (end 11.5 11.5) (layer "F.SilkS") (width 0.12))
    (fp_line (start 11.5 11.5) (end -11.5 11.5) (layer "F.SilkS") (width 0.12))
    (fp_line (start -11.5 11.5) (end -11.5 -11.5) (layer "F.SilkS") (width 0.12))
    
    ;; Pin A1 marker (corner)
    (fp_circle (center -10.5 -10.5) (end -10.2 -10.5) (layer "F.SilkS") (width 0.12))
    
    ;; Courtyard
    (fp_line (start -12 -12) (end 12 -12) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 12 -12) (end 12 12) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 12 12) (end -12 12) (layer "F.CrtYd") (width 0.05))
    (fp_line (start -12 12) (end -12 -12) (layer "F.CrtYd") (width 0.05))
    
    ;; Thermal pad (exposed pad, 31.5mm x 31.5mm area shadow — pads placed on grid)
    ;; BGA pads are generated programmatically; this defines the pad template
    (pad "A1" smd circle (at -10.5 -10.5) (size 0.35 0.35) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A2" smd circle (at -9.85 -10.5) (size 0.35 0.35) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "A3" smd circle (at -9.2 -10.5) (size 0.35 0.35) (layers "F.Cu" "F.Paste" "F.Mask"))
    ;; ... remaining 729 pads generated by BGA generator script
    
    ;; 3D model
    (model "${KIPRJMOD}/3dmodels/RK3576.step" (offset (xyz 0 0 0)) (scale (xyz 1 1 1)) (rotate (xyz 0 0 0)))
  )

  ;; ================================================================
  ;; QFN-60-0.4mm — RP2350B (7x7mm body)
  ;; ================================================================
  (footprint "QFN-60-0.4mm_7x7mm" (version 20240505) (generator "apex-one-cad")
    (layer "F.Cu")
    (descr "RP2350B QFN-60, 0.4mm pitch, 7x7mm body, 0.85mm pad width")
    (tags "QFN RP2350B")
    (attr smd)
    (fp_text reference "U**" (at 0 -4.5) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (fp_text value "QFN-60-0.4mm_7x7mm" (at 0 4.5) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    
    ;; Outline
    (fp_line (start -3.5 -3.5) (end 3.5 -3.5) (layer "F.SilkS") (width 0.12))
    (fp_line (start 3.5 -3.5) (end 3.5 3.5) (layer "F.SilkS") (width 0.12))
    (fp_line (start 3.5 3.5) (end -3.5 3.5) (layer "F.SilkS") (width 0.12))
    (fp_line (start -3.5 3.5) (end -3.5 -3.5) (layer "F.SilkS") (width 0.12))
    
    ;; Pin 1 marker
    (fp_circle (center -2.9 -2.9) (end -2.7 -2.9) (layer "F.SilkS") (width 0.12))
    
    ;; Courtyard
    (fp_line (start -4.2 -4.2) (end 4.2 -4.2) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 4.2 -4.2) (end 4.2 4.2) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 4.2 4.2) (end -4.2 4.2) (layer "F.CrtYd") (width 0.05))
    (fp_line (start -4.2 4.2) (end -4.2 -4.2) (layer "F.CrtYd") (width 0.05))
    
    ;; Thermal pad (exposed pad, 5.1mm x 5.1mm)
    (pad "EP" smd rect (at 0 0) (size 5.1 5.1) (layers "F.Cu" "F.Paste" "F.Mask")
      (paste_grid 0.4 0.4) (paste_ratio 0.5))
    
    ;; Side 1 pins (top, left to right: pins 1-15)
    (pad "1" smd rect (at -2.8 -3.275) (size 0.2 0.55) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "2" smd rect (at -2.4 -3.275) (size 0.2 0.55) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "3" smd rect (at -2.0 -3.275) (size 0.2 0.55) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "4" smd rect (at -1.6 -3.275) (size 0.2 0.55) (layers "F.Cu" "F.Paste" "F.Mask"))
    (pad "5" smd rect (at -1.2 -3.275) (size 0.2 0.55) (layers "F.Cu" "F.Paste" "F.Mask"))
    ;; ... remaining pins on all 4 sides
    
    ;; 3D model
    (model "${KIPRJMOD}/3dmodels/RP2350B.step" (offset (xyz 0 0 0)) (scale (xyz 1 1 1)) (rotate (xyz 0 0 0)))
  )

