      )
    )
    (comp (ref "U3")
      (value "LMS7002M")
      (footprint "ghostblade-footprints:QFN-64-0.5mm_9x9mm")
      (datasheet "https://limemicro.com/wp-content/uploads/2024/LMS7002M-Datasheet.pdf")
      (fields
        (field (name "Manufacturer") "Lime Microsystems")
        (field (name "MPN") "LMS7002M")
        (field (name "Category") "SDR")
      )
    )
    (comp (ref "U4")
      (value "CC1101")
      (footprint "ghostblade-footprints:QFN-20-0.5mm_4x4mm")
      (datasheet "https://www.ti.com/lit/ds/symlink/cc1101.pdf")
      (fields
        (field (name "Manufacturer") "Texas Instruments")
        (field (name "MPN") "CC1101")
        (field (name "Category") "RF")
      )
    )
    (comp (ref "U5")
