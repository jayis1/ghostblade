(export (version "E")
  (design
    (source "ghostblade.kicad_sch")
    (date "2026-06-14")
    (tool "GhostBlade CAD v1.0")
  )
  (components
    (comp (ref "U1")
      (value "RK3576")
      (footprint "ghostblade-footprints:FCBGA-732_0.65mm")
      (datasheet "https://www.rock-chips.com/uploads/pdf/RK3576%20Datasheet%20V1.0.pdf")
      (fields
        (field (name "Manufacturer") "Rockchip")
        (field (name "MPN") "RK3576")
        (field (name "Category") "SoC")
      )
    )
    (comp (ref "U2")
      (value "RP2350B")
      (footprint "ghostblade-footprints:QFN-60-0.4mm_7x7mm")
      (datasheet "https://datasheets.raspberrypi.com/rp2350/rp2350-datasheet.pdf")
      (fields
        (field (name "Manufacturer") "Raspberry Pi")
        (field (name "MPN") "RP2350B")
