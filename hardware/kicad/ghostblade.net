      (footprint "ghostblade-footprints:QFN-32-0.5mm_5x5mm")
      (datasheet "https://www.st.com/resource/en/datasheet/st25r3916.pdf")
      (fields
        (field (name "Manufacturer") "STMicroelectronics")
        (field (name "MPN") "ST25R3916")
        (field (name "Category") "NFC")
      )
    )
    (comp (ref "U6")
      (value "PE42422")
      (footprint "ghostblade-footprints:QFN-16-0.5mm_3x3mm")
      (datasheet "https://www.psemi.com/pdf/datasheets/pe42422ds.pdf")
      (fields
        (field (name "Manufacturer") "Peregrine Semiconductor")
        (field (name "MPN") "PE42422")
        (field (name "Category") "RF Switch")
      )
    )
    (comp (ref "U7")
      (value "MT7922")
      (footprint "ghostblade-footprints:LGA-145_14.5x13.5mm")
      (datasheet "https://www.mediatek.com/products/networking-and-connectivity/wi-fi-6e")
      (fields
        (field (name "Manufacturer") "MediaTek")
        (field (name "MPN") "MT7922")
        (field (name "Category") "WiFi/BT")
      )
    )
    (comp (ref "U8")
      (value "RK817")
      (footprint "ghostblade-footprints:QFN-48-0.5mm_6x6mm")
      (datasheet "https://www.rock-chips.com/uploads/pdf/RK817%20Datasheet.pdf")
      (fields
        (field (name "Manufacturer") "Rockchip")
        (field (name "MPN") "RK817")
        (field (name "Category") "PMIC")
      )
    )
    (comp (ref "U9")
      (value "K3LKBKB0BM-MGCJ")
      (footprint "ghostblade-footprints:FBGA-200_0.4mm_12x12mm")
      (datasheet "https://www.samsung.com/semiconductor/dram/lpddr5/")
      (fields
        (field (name "Manufacturer") "Samsung")
        (field (name "MPN") "K3LKBKB0BM-MGCJ")
        (field (name "Category") "Memory")
      )
    )
  )

  (libparts)

  (nets
    ;; ================================================================
    ;; INTER-PROCESSOR SPI BRIDGE (RK3576 <-> RP2350B)
    ;; ================================================================
    (net (code "1") (name "NET_SPI_CLK")
      (node (ref "U1") (pin "E7") (pinfunction "GPIO1_A2/SPI0_SCK"))
      (node (ref "U2") (pin "18") (pinfunction "PIN_18/SPI0_SCK"))
    )
    (net (code "2") (name "NET_SPI_MOSI")
      (node (ref "U1") (pin "E5") (pinfunction "GPIO1_A0/SPI0_TX"))
      (node (ref "U2") (pin "19") (pinfunction "PIN_19/SPI0_TX"))
    )
    (net (code "3") (name "NET_SPI_MISO")
      (node (ref "U1") (pin "E6") (pinfunction "GPIO1_A1/SPI0_RX"))
      (node (ref "U2") (pin "16") (pinfunction "PIN_16/SPI0_RX"))
    )
    (net (code "4") (name "NET_SPI_CS")
      (node (ref "U1") (pin "E8") (pinfunction "GPIO1_A3/SPI0_CSn"))
      (node (ref "U2") (pin "17") (pinfunction "PIN_17/SPI0_CSn"))
      (node (ref "R3") (pin "2") (pinfunction "2"))  ;; 4.7K pull-up to VDD_3V3
    )
    (net (code "5") (name "NET_INT_REQ")
      (node (ref "U2") (pin "20") (pinfunction "PIN_20/INT_REQ"))
      (node (ref "U1") (pin "F3") (pinfunction "GPIO1_B0/INT_REQ"))
    )
    (net (code "6") (name "NET_HOST_RDY")
      (node (ref "U1") (pin "F4") (pinfunction "GPIO1_B1/HOST_RDY"))
      (node (ref "U2") (pin "21") (pinfunction "PIN_21/HOST_RDY"))
    )
    (net (code "7") (name "NET_MCU_RESET")
      (node (ref "U1") (pin "F5") (pinfunction "GPIO1_B2/MCU_RESET"))
      (node (ref "U2") (pin "24") (pinfunction "PIN_24/RUN"))
    )

    ;; ================================================================
    ;; RF FRONTEND (RP2350B -> PE42422 -> ANTENNA PORTS)
    ;; ================================================================
    (net (code "10") (name "NET_ANT_SEL0")
      (node (ref "U2") (pin "2") (pinfunction "PIN_2/ANT_SEL0"))
      (node (ref "U6") (pin "1") (pinfunction "V1"))
    )
    (net (code "11") (name "NET_ANT_SEL1")
      (node (ref "U2") (pin "3") (pinfunction "PIN_3/ANT_SEL1"))
      (node (ref "U6") (pin "2") (pinfunction "V2"))
    )
    (net (code "12") (name "NET_SDR_TX_I_P")
      (node (ref "U3") (pin "60") (pinfunction "TX_I_P"))
      (node (ref "U1") (pin "L1") (pinfunction "MIPI_CSI_CLK_P"))
    )
    (net (code "13") (name "NET_SDR_TX_I_N")
      (node (ref "U3") (pin "61") (pinfunction "TX_I_N"))
      (node (ref "U1") (pin "L2") (pinfunction "MIPI_CSI_CLK_N"))
    )
    (net (code "14") (name "NET_SDR_TX_Q_P")
      (node (ref "U3") (pin "62") (pinfunction "TX_Q_P"))
      (node (ref "U1") (pin "M1") (pinfunction "MIPI_CSI_D0_P"))
    )
    (net (code "15") (name "NET_SDR_TX_Q_N")
      (node (ref "U3") (pin "63") (pinfunction "TX_Q_N"))
      (node (ref "U1") (pin "M2") (pinfunction "MIPI_CSI_D0_N"))
    )

    ;; SDR SPI Control (RP2350B -> LMS7002M)
    (net (code "20") (name "NET_SDR_SPI_SCK")
      (node (ref "U2") (pin "27") (pinfunction "PIN_27/SPI1_SCK"))
      (node (ref "U3") (pin "55") (pinfunction "SCLK"))
    )
    (net (code "21") (name "NET_SDR_SPI_TX")
      (node (ref "U2") (pin "28") (pinfunction "PIN_28/SPI1_TX"))
      (node (ref "U3") (pin "56") (pinfunction "SDI"))
    )
    (net (code "22") (name "NET_SDR_SPI_RX")
      (node (ref "U2") (pin "29") (pinfunction "PIN_29/SPI1_RX"))
      (node (ref "U3") (pin "57") (pinfunction "SDO"))
    )
    (net (code "23") (name "NET_SDR_SPI_CSN")
      (node (ref "U2") (pin "30") (pinfunction "PIN_30/SPI1_CSn"))
      (node (ref "U3") (pin "58") (pinfunction "CSn"))
    )
    (net (code "24") (name "NET_SDR_RESET")
      (node (ref "U2") (pin "31") (pinfunction "PIN_31/SDR_RST"))
      (node (ref "U3") (pin "59") (pinfunction "RESETn"))
    )
    (net (code "25") (name "NET_SDR_LNA_EN")
      (node (ref "U2") (pin "34") (pinfunction "PIN_34/SDR_LNA_EN"))
      (node (ref "U3") (pin "64") (pinfunction "GPIO0"))
    )

    ;; PE42422 Antenna Switch -> SMA Connectors
    (net (code "30") (name "NET_ANT_SDR")
      (node (ref "U6") (pin "16") (pinfunction "RFC"))
      (node (ref "J3") (pin "1"))
    )
    (net (code "31") (name "NET_ANT_SUBGHZ")
      (node (ref "U6") (pin "9") (pinfunction "RF1"))
      (node (ref "U4") (pin "20") (pinfunction "RF_N"))
    )
    (net (code "32") (name "NET_ANT_WIFI_2G")
      (node (ref "U6") (pin "11") (pinfunction "RF2"))
      (node (ref "J5") (pin "1"))
    )
    (net (code "33") (name "NET_ANT_WIFI_5G")
      (node (ref "U6") (pin "13") (pinfunction "RF3"))
      (node (ref "J6") (pin "1"))
    )

    ;; CC1101 Sub-GHz
    (net (code "40") (name "NET_CC_SPI_SCK")
      (node (ref "U2") (pin "8") (pinfunction "PIN_8/SPI2_SCK"))
      (node (ref "U4") (pin "5") (pinfunction "SCLK"))
    )
    (net (code "41") (name "NET_CC_SPI_TX")
      (node (ref "U2") (pin "9") (pinfunction "PIN_9/SPI2_TX"))
      (node (ref "U4") (pin "6") (pinfunction "SI"))
    )
    (net (code "42") (name "NET_CC_SPI_RX")
      (node (ref "U2") (pin "12") (pinfunction "PIN_12/SPI2_RX"))
      (node (ref "U4") (pin "7") (pinfunction "SO"))
    )
    (net (code "43") (name "NET_CC_SPI_CSN")
      (node (ref "U2") (pin "10") (pinfunction "PIN_10/CC_CSn"))
      (node (ref "U4") (pin "8") (pinfunction "CSn"))
    )
    (net (code "44") (name "NET_CC_GDO0")
      (node (ref "U2") (pin "13") (pinfunction "PIN_13/CC_GDO0"))
      (node (ref "U4") (pin "9") (pinfunction "GDO0"))
    )
    (net (code "45") (name "NET_CC_GDO2")
      (node (ref "U2") (pin "14") (pinfunction "PIN_14/CC_GDO2"))
      (node (ref "U4") (pin "10") (pinfunction "GDO2"))
    )

    ;; ST25R3916 NFC
    (net (code "50") (name "NET_NFC_SPI_SCK")
      (node (ref "U2") (pin "40") (pinfunction "PIN_40/NFC_SCK"))
      (node (ref "U5") (pin "3") (pinfunction "SCK"))
    )
    (net (code "51") (name "NET_NFC_SPI_MOSI")
      (node (ref "U2") (pin "41") (pinfunction "PIN_41/NFC_MOSI"))
      (node (ref "U5") (pin "4") (pinfunction "MOSI"))
    )
    (net (code "52") (name "NET_NFC_SPI_MISO")
      (node (ref "U2") (pin "42") (pinfunction "PIN_42/NFC_MISO"))
      (node (ref "U5") (pin "5") (pinfunction "MISO"))
    )
    (net (code "53") (name "NET_NFC_SPI_CSN")
      (node (ref "U2") (pin "43") (pinfunction "PIN_43/NFC_CSn"))
      (node (ref "U5") (pin "6") (pinfunction "CSn"))
    )
    (net (code "54") (name "NET_NFC_IRQ")
      (node (ref "U2") (pin "44") (pinfunction "PIN_44/NFC_IRQ"))
      (node (ref "U5") (pin "7") (pinfunction "IRQ"))
    )
    (net (code "55") (name "NET_NFC_ANT1")
      (node (ref "U5") (pin "28") (pinfunction "ANT1"))
    )
    (net (code "56") (name "NET_NFC_ANT2")
      (node (ref "U5") (pin "29") (pinfunction "ANT2"))
    )

    ;; ================================================================
    ;; POWER NETS
    ;; ================================================================
    (net (code "100") (name "VDD_CORE")
      (node (ref "U8") (pin "1") (pinfunction "BUCK1_VOUT"))
      (node (ref "U1") (pin "A1") (pinfunction "VDD_CORE"))
      (node (ref "U1") (pin "A5") (pinfunction "VDD_CORE"))
      (node (ref "U1") (pin "A10") (pinfunction "VDD_CORE"))
    )
    (net (code "101") (name "VDD_DDR")
      (node (ref "U8") (pin "5") (pinfunction "BUCK2_VOUT"))
      (node (ref "U1") (pin "C1") (pinfunction "VDD_DDR"))
      (node (ref "U1") (pin "C8") (pinfunction "VDD_DDR"))
      (node (ref "U9") (pin "A1") (pinfunction "VDD"))
    )
    (net (code "102") (name "VDD_LOGIC")
      (node (ref "U8") (pin "9") (pinfunction "BUCK3_VOUT"))
      (node (ref "U1") (pin "B1") (pinfunction "VDD_LOGIC"))
      (node (ref "U1") (pin "B6") (pinfunction "VDD_LOGIC"))
    )
    (net (code "103") (name "VDD_3V3")
      (node (ref "U8") (pin "13") (pinfunction "BUCK4_VOUT"))
      (node (ref "U1") (pin "D1") (pinfunction "VDD_3V3"))
      (node (ref "U2") (pin "1") (pinfunction "VDD_3V3"))
      (node (ref "U2") (pin "23") (pinfunction "VDD_3V3"))
      (node (ref "U4") (pin "15") (pinfunction "VDD"))
      (node (ref "U4") (pin "4") (pinfunction "VDD"))
    )
    (net (code "104") (name "VDD_1V8")
      (node (ref "U12") (pinfunction "VOUT"))
      (node (ref "U7") (pin "A2") (pinfunction "VDD_1V8"))
    )
    (net (code "105") (name "SDR_1V2")
      (node (ref "U15") (pinfunction "VOUT"))
      (node (ref "U3") (pin "1") (pinfunction "VDD_1V2"))
    )
    (net (code "106") (name "SDR_1V8")
      (node (ref "U8") (pin "20") (pinfunction "LDO1_VOUT"))
      (node (ref "U3") (pin "45") (pinfunction "VDD_1V8"))
    )
    (net (code "107") (name "SDR_3V3_RF")
      (node (ref "U8") (pin "22") (pinfunction "LDO2_VOUT"))
      (node (ref "U3") (pin "30") (pinfunction "VDD_3V3_RF"))
      (node (ref "U6") (pin "3") (pinfunction "VDD"))
    )
    (net (code "108") (name "VBAT")
      (node (ref "U8") (pin "30") (pinfunction "VBAT"))
      (node (ref "U10") (pinfunction "VOUT"))
    )
    (net (code "109") (name "VBUS")
      (node (ref "U8") (pin "35") (pinfunction "VBUS"))
      (node (ref "J2") (pinfunction "VBUS"))
    )
    (net (code "110") (name "GND")
      (node (ref "U1") (pin "A20") (pinfunction "GND"))
      (node (ref "U1") (pin "B20") (pinfunction "GND"))
      (node (ref "U1") (pin "C20") (pinfunction "GND"))
      (node (ref "U2") (pin "2") (pinfunction "GND"))
      (node (ref "U2") (pin "22") (pinfunction "GND"))
      (node (ref "U3") (pin "EP") (pinfunction "GND"))
      (node (ref "U4") (pin "EP") (pinfunction "GND"))
      (node (ref "U5") (pin "EP") (pinfunction "GND"))
      (node (ref "U6") (pin "EP") (pinfunction "GND"))
      (node (ref "U7") (pin "A3") (pinfunction "GND"))
      (node (ref "U8") (pin "EP") (pinfunction "GND"))
      (node (ref "U9") (pin "A7") (pinfunction "VSS"))
    )

    ;; ================================================================
    ;; I2C BUS (RK3576 <-> PMIC, NFC secondary)
    ;; ================================================================
    (net (code "120") (name "NET_I2C1_SDA")
      (node (ref "U1") (pin "V1") (pinfunction "I2C1_SDA"))
      (node (ref "U8") (pin "40") (pinfunction "I2C_SDA"))
      (node (ref "R1") (pin "1"))  ;; 10K pull-up to VDD_3V3
    )
    (net (code "121") (name "NET_I2C1_SCL")
      (node (ref "U1") (pin "V2") (pinfunction "I2C1_SCL"))
      (node (ref "U8") (pin "41") (pinfunction "I2C_SCL"))
      (node (ref "R2") (pin "1"))  ;; 10K pull-up to VDD_3V3
    )

    ;; ================================================================
    ;; PCIe (RK3576 <-> MT7922 Wi-Fi)
    ;; ================================================================
    (net (code "130") (name "NET_PCIE_TX_P")
      (node (ref "U1") (pin "P1") (pinfunction "PCIE_TX0_P"))
      (node (ref "U7") (pin "B1") (pinfunction "PCIE_TX_P"))
    )
    (net (code "131") (name "NET_PCIE_TX_N")
      (node (ref "U1") (pin "P2") (pinfunction "PCIE_TX0_N"))
      (node (ref "U7") (pin "B2") (pinfunction "PCIE_TX_N"))
    )
    (net (code "132") (name "NET_PCIE_RX_P")
      (node (ref "U1") (pin "R1") (pinfunction "PCIE_RX0_P"))
      (node (ref "U7") (pin "B3") (pinfunction "PCIE_RX_P"))
    )

    ;; ================================================================
    ;; eMMC (RK3576 <-> eMMC)
    ;; ================================================================
    (net (code "140") (name "NET_EMMC_CLK")
      (node (ref "U1") (pin "T1") (pinfunction "eMMC_CLK"))
      (node (ref "U10") (pinfunction "CLK"))
    )
    (net (code "141") (name "NET_EMMC_CMD")
      (node (ref "U1") (pin "T2") (pinfunction "eMMC_CMD"))
      (node (ref "U10") (pinfunction "CMD"))
    )
    (net (code "142") (name "NET_EMMC_D0")
      (node (ref "U1") (pin "T3") (pinfunction "eMMC_D0"))
      (node (ref "U10") (pinfunction "D0"))
    )

    ;; ================================================================
    ;; USB-C (RK3576 <-> USB-C Connector)
    ;; ================================================================
    (net (code "150") (name "NET_USB3_TX_P")
      (node (ref "U1") (pin "U1") (pinfunction "USB3_TX_P"))
      (node (ref "J2") (pinfunction "TX1+"))
    )
  )
)