# GhostBlade Project — EditorConfig
# https://editorconfig.org/

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C source files
[*.{c,h}]
indent_size = 4

# Device tree files
[*.dts]
indent_size = 4

# Makefiles (must use tabs)
[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

# CMake files
[CMakeLists.txt]
indent_size = 2

[*.cmake]
indent_size = 2

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Python files
[*.py]
indent_size = 4

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# CSV files
[*.csv]
indent_size = 1

# KiCad project files (S-expression format)
[*.kicad_pro]
indent_style = space
indent_size = 2

# KiCad symbol/footprint files
[*.{kicad_sym,kicad_mod}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 4

# Linker scripts
[*.ld]
indent_size = 4

# HTML files
[*.html]
indent_size = 2